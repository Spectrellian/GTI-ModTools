<Window x:Class="GTI.ModTools.WPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        mc:Ignorable="d"
        Title="GTI-ModTools"
        Height="760"
        Width="1240"
        MinHeight="620"
        MinWidth="1000"
        WindowStartupLocation="CenterScreen"
        Background="#0A0F1A"
        FontFamily="Bahnschrift">

    <Window.Resources>
        <SolidColorBrush x:Key="AppBgBrush" Color="#0A0F1A" />
        <SolidColorBrush x:Key="AppBgAltBrush" Color="#0F1728" />
        <SolidColorBrush x:Key="PanelBrush" Color="#121D31" />
        <SolidColorBrush x:Key="PanelBorderBrush" Color="#2D3F5D" />
        <SolidColorBrush x:Key="PanelHeaderBrush" Color="#A9C9FF" />
        <SolidColorBrush x:Key="BodyTextBrush" Color="#EAF2FF" />
        <SolidColorBrush x:Key="MutedTextBrush" Color="#9FB3D1" />
        <SolidColorBrush x:Key="AccentBrush" Color="#22A6B3" />
        <SolidColorBrush x:Key="AccentSoftBrush" Color="#184953" />

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource BodyTextBrush}" />
        </Style>
        <Style TargetType="Label">
            <Setter Property="Foreground" Value="{StaticResource BodyTextBrush}" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>
        <Style TargetType="GroupBox">
            <Setter Property="Foreground" Value="{StaticResource PanelHeaderBrush}" />
            <Setter Property="Margin" Value="0,0,0,10" />
            <Setter Property="Padding" Value="12" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="GroupBox">
                        <Grid>
                            <Border CornerRadius="10"
                                    BorderThickness="1"
                                    BorderBrush="{StaticResource PanelBorderBrush}"
                                    Background="{StaticResource PanelBrush}">
                                <ContentPresenter Margin="10,16,10,10" />
                            </Border>
                            <Border Margin="12,0,0,0"
                                    Padding="8,0"
                                    Background="{StaticResource PanelBrush}"
                                    HorizontalAlignment="Left"
                                    VerticalAlignment="Top">
                                <TextBlock Text="{TemplateBinding Header}"
                                           FontWeight="Bold"
                                           Foreground="{StaticResource PanelHeaderBrush}" />
                            </Border>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="TextBox" BasedOn="{StaticResource MaterialDesignOutlinedTextBox}">
            <Setter Property="Margin" Value="0,0,0,2" />
            <Setter Property="Background" Value="#0D1422" />
            <Setter Property="Foreground" Value="{StaticResource BodyTextBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource PanelBorderBrush}" />
        </Style>
        <Style TargetType="Button" BasedOn="{StaticResource MaterialDesignRaisedButton}">
            <Setter Property="Padding" Value="12,7" />
            <Setter Property="Margin" Value="0,0,8,0" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Background" Value="{StaticResource AccentBrush}" />
            <Setter Property="Foreground" Value="#031015" />
            <Setter Property="materialDesign:ButtonAssist.CornerRadius" Value="8" />
        </Style>
        <Style TargetType="ComboBox" BasedOn="{StaticResource MaterialDesignOutlinedComboBox}">
            <Setter Property="Background" Value="#0D1422" />
            <Setter Property="Foreground" Value="{StaticResource BodyTextBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource PanelBorderBrush}" />
        </Style>
        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="{StaticResource BodyTextBrush}" />
            <Setter Property="Margin" Value="0,0,16,0" />
        </Style>
        <Style TargetType="TabControl" BasedOn="{StaticResource MaterialDesignTabControl}">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
        </Style>
        <Style TargetType="TabItem" BasedOn="{StaticResource MaterialDesignTabItem}">
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Padding" Value="16,10" />
            <Setter Property="Margin" Value="0,0,8,0" />
            <Setter Property="Foreground" Value="{StaticResource BodyTextBrush}" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>
        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="#0E1727" />
            <Setter Property="Foreground" Value="{StaticResource BodyTextBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource PanelBorderBrush}" />
            <Setter Property="RowBackground" Value="#142239" />
            <Setter Property="AlternatingRowBackground" Value="#112035" />
            <Setter Property="HorizontalGridLinesBrush" Value="#2B3E5E" />
            <Setter Property="VerticalGridLinesBrush" Value="#243451" />
            <Setter Property="HeadersVisibility" Value="Column" />
            <Setter Property="materialDesign:DataGridAssist.CellPadding" Value="10,8" />
            <Setter Property="materialDesign:DataGridAssist.ColumnHeaderPadding" Value="10,8" />
        </Style>
        <Style TargetType="ListBox">
            <Setter Property="Background" Value="#0E1727" />
            <Setter Property="Foreground" Value="{StaticResource BodyTextBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource PanelBorderBrush}" />
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Offset="0" Color="#0A0F1A" />
                <GradientStop Offset="1" Color="#101C31" />
            </LinearGradientBrush>
        </Grid.Background>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Margin="12,12,12,8"
                CornerRadius="12"
                Padding="14,12"
                Background="#15233A"
                BorderBrush="#314A72"
                BorderThickness="1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="GTI-ModTools"
                               FontSize="22"
                               FontWeight="Bold"
                               Foreground="#EAF2FF" />
                    <TextBlock Text="Pokemon Gates to Infinity mod workflow"
                               Foreground="{StaticResource MutedTextBrush}"
                               Margin="0,2,0,0" />
                </StackPanel>
                <Border Grid.Column="1"
                        VerticalAlignment="Center"
                        Background="{StaticResource AccentSoftBrush}"
                        BorderBrush="{StaticResource AccentBrush}"
                        BorderThickness="1"
                        CornerRadius="999"
                        Padding="10,4">
                    <TextBlock Text="WPF Workspace"
                               Foreground="#BFE8ED"
                               FontWeight="SemiBold" />
                </Border>
            </Grid>
        </Border>

        <TabControl Grid.Row="1" Margin="12,0,12,12">
            <TabItem Header="Binary Explorer">
                <Grid Margin="12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <GroupBox Header="Source + Output" Grid.Row="0" Padding="10">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <Label Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" Margin="0,0,8,8">Input (.bin file or folder)</Label>
                            <TextBox x:Name="FarcInputPathTextBox"
                                     Grid.Row="0"
                                     Grid.Column="1"
                                     Margin="0,0,8,8"
                                     TextChanged="PersistToolConfig_TextChanged" />
                            <StackPanel Grid.Row="0" Grid.Column="2" Orientation="Horizontal">
                                <Button Content="Browse File" Click="BrowseFarcInputFile_Click" />
                                <Button Content="Browse Folder" Margin="0,0,0,0" Click="BrowseFarcInputFolder_Click" />
                            </StackPanel>

                            <Label Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" Margin="0,0,8,0">Output folder</Label>
                            <TextBox x:Name="FarcOutputPathTextBox"
                                     Grid.Row="1"
                                     Grid.Column="1"
                                     Margin="0,0,8,0"
                                     TextChanged="PersistToolConfig_TextChanged" />
                            <Button Grid.Row="1" Grid.Column="2" Content="Browse Output" Margin="0,0,0,0" Click="BrowseFarcOutput_Click" />
                        </Grid>
                    </GroupBox>

                    <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,4,0,10">
                        <CheckBox x:Name="FarcRecursiveCheckBox"
                                  Content="Recursive scan"
                                  Margin="0,0,20,0"
                                  IsChecked="True"
                                  Checked="PersistToolConfig_RoutedChanged"
                                  Unchecked="PersistToolConfig_RoutedChanged" />
                        <ItemsControl x:Name="ArchiveOptionsItemsControl" Margin="0,0,20,0">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Horizontal" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <CheckBox Content="{Binding DisplayName}"
                                              IsChecked="{Binding IsEnabled, Mode=TwoWay}" />
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <Button Content="Scan Files" Click="ScanFarc_Click" />
                        <Button Content="Extract Selected" Click="ExtractSelectedFarc_Click" />
                        <Button Content="Extract All" Click="ExtractAllFarc_Click" />
                    </StackPanel>

                    <Grid Grid.Row="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*" />
                            <ColumnDefinition Width="3*" />
                        </Grid.ColumnDefinitions>

                        <GroupBox Header="Detected files" Grid.Column="0" Padding="8" Margin="0,0,10,0">
                            <DataGrid x:Name="FarcFilesDataGrid"
                                      SelectionChanged="FarcFilesDataGrid_SelectionChanged"
                                      AutoGenerateColumns="False"
                                      CanUserSortColumns="True"
                                      IsReadOnly="True"
                                      SelectionMode="Single"
                                      SelectionUnit="FullRow"
                                      GridLinesVisibility="Horizontal">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="160" />
                                    <DataGridTextColumn Header="Type" Binding="{Binding Type}" Width="90" />
                                    <DataGridTextColumn Header="Size" Binding="{Binding SizeDisplay}" SortMemberPath="FileSize" Width="95" />
                                    <DataGridTextColumn Header="Path" Binding="{Binding RelativePath}" Width="*" />
                                    <DataGridTextColumn Header="Summary" Binding="{Binding Summary}" Width="220" />
                                </DataGrid.Columns>
                            </DataGrid>
                        </GroupBox>

                        <Grid Grid.Column="1">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="2*" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <GroupBox Header="Entries" Grid.Row="0" Padding="8" Margin="0,0,0,10">
                                <DataGrid x:Name="FarcSectionsDataGrid"
                                          AutoGenerateColumns="False"
                                          IsReadOnly="True"
                                          GridLinesVisibility="Horizontal">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="120" />
                                        <DataGridTextColumn Header="Offset" Binding="{Binding OffsetHex}" Width="90" />
                                        <DataGridTextColumn Header="Length" Binding="{Binding Length}" Width="90" />
                                        <DataGridTextColumn Header="Kind" Binding="{Binding Kind}" Width="90" />
                                        <DataGridTextColumn Header="Details" Binding="{Binding Details}" Width="*" />
                                    </DataGrid.Columns>
                                </DataGrid>
                            </GroupBox>

                            <GroupBox Header="Referenced names" Grid.Row="1" Padding="8">
                                <ListBox x:Name="FarcNamesListBox" />
                            </GroupBox>
                        </Grid>
                    </Grid>

                    <Border Grid.Row="3"
                            Margin="0,8,0,0"
                            Padding="10,8"
                            CornerRadius="8"
                            BorderBrush="#2F486F"
                            BorderThickness="1"
                            Background="#12213A">
                        <TextBlock x:Name="FarcStatusTextBlock"
                                   Foreground="#B2D2FF"
                                   TextWrapping="Wrap" />
                    </Border>
                </Grid>
            </TabItem>

            <TabItem Header="Image Converter">
                <Grid Margin="12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <GroupBox Header="Paths" Grid.Row="0" Padding="10">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <Label Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" Margin="0,0,8,8">Image input</Label>
                            <TextBox x:Name="ImageInputPathTextBox"
                                     Grid.Row="0"
                                     Grid.Column="1"
                                     Margin="0,0,8,8"
                                     TextChanged="PersistToolConfig_TextChanged" />
                            <Button Grid.Row="0" Grid.Column="2" Content="Browse" Margin="0,0,0,8" Click="BrowseImageInput_Click" />

                            <Label Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" Margin="0,0,8,8">Image output</Label>
                            <TextBox x:Name="ImageOutputPathTextBox"
                                     Grid.Row="1"
                                     Grid.Column="1"
                                     Margin="0,0,8,8"
                                     TextChanged="PersistToolConfig_TextChanged" />
                            <Button Grid.Row="1" Grid.Column="2" Content="Browse" Margin="0,0,0,8" Click="BrowseImageOutput_Click" />

                            <Label Grid.Row="2" Grid.Column="0" VerticalAlignment="Center" Margin="0,0,8,0">Base (GTI image_2d)</Label>
                            <TextBox x:Name="BasePathTextBox" Grid.Row="2" Grid.Column="1" Margin="0,0,8,0" TextChanged="BasePathTextBox_TextChanged" />
                            <Button Grid.Row="2" Grid.Column="2" Content="Browse" Margin="0,0,0,0" Click="BrowseBasePath_Click" />
                        </Grid>
                    </GroupBox>

                    <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,4,0,8">
                        <Label VerticalAlignment="Center" Margin="0,0,8,0">Optional PNG -&gt; IMG format:</Label>
                        <ComboBox x:Name="ImageFormatComboBox" Width="220" SelectedIndex="0">
                            <ComboBoxItem Content="Auto (infer/base)" Tag="auto" />
                            <ComboBoxItem Content="rgb8 (0x02)" Tag="rgb8" />
                            <ComboBoxItem Content="rgba8888 (0x03)" Tag="rgba8888" />
                        </ComboBox>
                    </StackPanel>

                    <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,8">
                        <Button Content="Convert IMG -&gt; PNG" Click="ConvertToPng_Click" />
                        <Button Content="Convert PNG -&gt; IMG" Click="ConvertToImg_Click" />
                        <Button Content="Auto Convert" Click="AutoConvert_Click" />
                    </StackPanel>

                    <GroupBox Grid.Row="3" Header="Conversion log" Padding="8">
                        <TextBox x:Name="ImageLogTextBox"
                                 IsReadOnly="True"
                                 VerticalScrollBarVisibility="Auto"
                                 TextWrapping="Wrap"
                                 AcceptsReturn="True"
                                 FontFamily="Consolas"
                                 FontSize="13"
                                 Background="#0E1727"
                                 BorderBrush="#2D3F5D"
                                 Foreground="#D8E7FF" />
                    </GroupBox>
                </Grid>
            </TabItem>
        </TabControl>

        <Grid x:Name="BaseOverlay"
              Background="#C0101010"
              Visibility="Collapsed"
              Panel.ZIndex="100">
            <Border Width="520"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    CornerRadius="8"
                    BorderThickness="2"
                    BorderBrush="#FFCE6A"
                    Background="#1A2230"
                    Padding="20">
                <StackPanel>
                    <TextBlock Text="No base data from GTI"
                               FontSize="28"
                               FontWeight="Bold"
                               Foreground="#FFD27A"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,12" />
                    <TextBlock Text="PNG -&gt; IMG conversion needs original GTI files in Base/ (at least .img and .bsji)."
                               TextWrapping="Wrap"
                               FontSize="15"
                               HorizontalAlignment="Center"
                               TextAlignment="Center"
                               Margin="0,0,0,20" />
                    <Button Content="Close"
                            Width="120"
                            HorizontalAlignment="Center"
                            Margin="0"
                            Click="CloseOverlay_Click" />
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>
